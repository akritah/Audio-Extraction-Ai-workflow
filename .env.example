# Copy this file to .env and fill in your values.
# The backend reads these at startup.

# HuggingFace token — only needed the first time to download pyannote models.
# Once cached locally (~/.cache/huggingface) this can be left blank.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Whisper model size: tiny / base / small / medium / large-v3
# Larger = more accurate, slower, more RAM.
# On CPU: medium is a reasonable tradeoff (~2GB RAM, ~0.4x realtime)
# With GPU: use large-v3 for best accuracy
WHISPER_MODEL=medium

# cpu or cuda
WHISPER_DEVICE=cpu

# Ollama endpoint (leave as-is if running locally)
OLLAMA_URL=http://localhost:11434

# Model to use for extraction and summarization
# Options: qwen2.5:7b  |  phi3.5:3.8b  |  gemma2:9b  |  qwen2.5:14b
OLLAMA_MODEL=qwen2.5:7b
